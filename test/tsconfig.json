{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "@shapeshift-labs/frontier-dom",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "types.ts",
    "tsx.tsx"
  ]
}
